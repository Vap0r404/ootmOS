ENTRY(start)

SECTIONS
{
  . = 1M;

  .multiboot_header :
  {
    KEEP(*(.multiboot_header))
  }

  .text :
  {
    *(.text*)
  }

  .rodata :
  {
    *(.rodata*)
  }

  .data :
  {
    *(.data*)
  }

  .bss :
  {
    *(.bss*)
    *(COMMON)
  }

  /DISCARD/ :
  {
    *(.comment)
    *(.eh_frame)
  }
}

